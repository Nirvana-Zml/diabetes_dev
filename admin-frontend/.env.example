# API 基础地址（现有服务）
VITE_API_BASE=/api/v1

# 新服务 API 基础地址
VITE_API_V2_BASE=/api/v2

# Mock 模式（true=不请求真实后端；封面图上传等功能必须设为 false）
VITE_USE_MOCK=false

# 用户端门户地址（管理后台「返回用户端」链接）
VITE_USER_PORTAL_URL=http://localhost:5173

# Dify 资讯初稿工作流（开发环境经 Vite 代理 /dify-proxy 访问，避免 CORS）
VITE_DIFY_USE_PROXY=true
VITE_DIFY_PROXY_PREFIX=/dify-proxy
VITE_DIFY_PROXY_TARGET=http://localhost:58080
