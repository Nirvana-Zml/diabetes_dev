# API 基础地址（现有服务）
VITE_API_BASE=/api/v1

# 新服务 API 基础地址
VITE_API_V2_BASE=/api/v2

# 管理后台地址（与用户端分离）
VITE_ADMIN_PORTAL_URL=http://localhost:5174

# 是否使用 Mock 占位（true=不请求真实后端，false=请求真实 API）
VITE_USE_MOCK=true

# Dify 工作流 URL 占位（对接时替换为真实地址）
VITE_DIFY_QA_URL=__PLACEHOLDER_DIFY_QA_WORKFLOW__
VITE_DIFY_CONSULTATION_URL=__PLACEHOLDER_DIFY_CONSULTATION_WORKFLOW__
VITE_DIFY_RISK_URL=__PLACEHOLDER_DIFY_RISK_WORKFLOW__
# Dify 方案生成工作流（默认 API Key 见 backend/plan-service application.yml）
VITE_DIFY_PLAN_URL=__PLACEHOLDER_DIFY_PLAN_WORKFLOW__
VITE_DIFY_ARTICLE_DRAFT_URL=__PLACEHOLDER_DIFY_ARTICLE_DRAFT_WORKFLOW__
