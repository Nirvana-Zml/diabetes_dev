# MySQL
MYSQL_ROOT_PASSWORD=your_secure_password
MYSQL_DATABASE=diabetes_assistant

# Redis（checkin-service / article-service 缓存；可与 Dify 共用实例，业务 Key 前缀 diabetes:）
REDIS_PASSWORD=your_redis_password

# QQ 邮箱 SMTP（user-service 验证码邮件）
MAIL_USERNAME=your_qq_email@qq.com
MAIL_PASSWORD=your_qq_smtp_auth_code

# JWT（所有 backend 服务须使用同一密钥）
JWT_SECRET=diabetes_jwt_secret_key_at_least_32_chars

# MinIO（user-service 头像存储）
MINIO_USER=minio
MINIO_PASSWORD=minio123456
MINIO_PUBLIC_URL=http://localhost:9000

# Dify（health-service 在 Docker 内访问宿主机 Dify，用 host.docker.internal，不要用 localhost）
DIFY_BASE_URL=http://host.docker.internal:58080
DIFY_RISK_TRIGGER_MODE=api
DIFY_RISK_API_KEY=app-XuGJ0yp3XhejVrzE88dL1kHk
DIFY_RISK_INPUT_VAR=flat
DIFY_RISK_INPUT_FORMAT=object

# 健康方案生成工作流（plan-service；开始节点 7 变量平铺传入 inputs）
DIFY_PLAN_API_KEY=app-fHORDdQjVq9GVtLcyD9WaL3g
DIFY_PLAN_RESPONSE_MODE=blocking
DIFY_HEALTH_TREND_API_KEY=app-2aWyzKF49e9qp1WDuGSsUmlE
DIFY_HEALTH_TREND_RESPONSE_MODE=blocking

# 主动健康干预编排（user-service）
INTERVENTION_COOLDOWN_HOURS=4
INTERVENTION_DAILY_ALERT_MAX=2
INTERVENTION_SCHEDULER_CRON=0 0 8 * * ?

# 资讯个性化推荐工作流（article-service；开始节点 4 变量平铺）
DIFY_ARTICLE_RECOMMEND_API_KEY=app-Af1Iv6Y51WrahbDXQMBDUy7f
DIFY_ARTICLE_RECOMMEND_INPUT_VAR=flat
DIFY_ARTICLE_RECOMMEND_INPUT_FORMAT=object
DIFY_ARTICLE_RECOMMEND_RESPONSE_MODE=blocking

# 打卡 AI 行为分析工作流（checkin-service，开始节点 7 变量平铺）
DIFY_CHECKIN_API_KEY=app-kFnPhD8YUmCfG2DeHubp1Scc
DIFY_CHECKIN_RESPONSE_MODE=blocking

# 科普问答 Chatbot（home-service，Milvus 预检索 + Dify Chat API streaming）
DIFY_QA_API_KEY=app-nz9nEZ6qpQNJBr5Vd3xbD2x0

# AI 模拟医生问诊工作流（consultation-service，开始节点 6 变量平铺）
DIFY_CONSULTATION_API_KEY=app-seD1XofriTMjAWgb8A2xX434
DIFY_CONSULTATION_RESPONSE_MODE=blocking
DIFY_CONSULTATION_TIMEOUT_SECONDS=120

# Dify 调用 health-service 内部 API
DIFY_INTERNAL_KEY=LoginAuth2026

# Milvus（article-service 语义推荐 Phase 3）
MILVUS_ENABLED=true
MILVUS_HOST=localhost
MILVUS_PORT=19530
# 须与 Embedding 模型输出维度一致（qwen3-embedding:0.6b=1024，nomic-embed-text=768，local=384）
MILVUS_DIMENSION=1024
# local=内置哈希向量；openai=OpenAI 兼容 API（Ollama / OpenAI / DashScope 等）
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b

