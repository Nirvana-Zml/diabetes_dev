# MySQL
MYSQL_ROOT_PASSWORD=your_secure_password
MYSQL_DATABASE=diabetes_assistant

# Redis（checkin-service / article-service 缓存；可与 Dify 共用实例，业务 Key 前缀 diabetes:）
REDIS_PASSWORD=your_redis_password

# QQ 邮箱 SMTP（user-service 验证码邮件）
MAIL_USERNAME=your_qq_email@qq.com
MAIL_PASSWORD=your_qq_smtp_auth_code

# JWT（所有 backend 服务须使用同一密钥，至少 32 字符）
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# MinIO（user-service 头像存储）
MINIO_USER=minio
MINIO_PASSWORD=your_minio_password
MINIO_PUBLIC_URL=http://localhost:9000

# Dify（health-service 在 Docker 内访问宿主机 Dify，用 host.docker.internal，不要用 localhost）
DIFY_BASE_URL=http://host.docker.internal:58080
DIFY_RISK_TRIGGER_MODE=api
DIFY_RISK_API_KEY=app-your_dify_risk_api_key
DIFY_RISK_INPUT_VAR=flat
DIFY_RISK_INPUT_FORMAT=object
DIFY_RISK_WEBHOOK_PATH=/triggers/webhook/your_webhook_id

# 健康方案生成工作流（plan-service；开始节点 7 变量平铺传入 inputs）
DIFY_PLAN_API_KEY=app-your_dify_plan_api_key
DIFY_PLAN_RESPONSE_MODE=blocking
DIFY_HEALTH_TREND_API_KEY=app-your_dify_health_trend_api_key
DIFY_HEALTH_TREND_RESPONSE_MODE=blocking

# 主动健康干预编排（user-service）
INTERVENTION_COOLDOWN_HOURS=4
INTERVENTION_DAILY_ALERT_MAX=2
INTERVENTION_SCHEDULER_CRON=0 0 8 * * ?

# 资讯个性化推荐工作流（article-service；开始节点 4 变量平铺）
DIFY_ARTICLE_RECOMMEND_API_KEY=app-your_dify_article_recommend_api_key
DIFY_ARTICLE_RECOMMEND_INPUT_VAR=flat
DIFY_ARTICLE_RECOMMEND_INPUT_FORMAT=object
DIFY_ARTICLE_RECOMMEND_RESPONSE_MODE=blocking

# 资讯初稿工作流（admin-frontend / article-service）
DIFY_ARTICLE_DRAFT_API_KEY=app-your_dify_article_draft_api_key

# 打卡 AI 行为分析工作流（checkin-service，开始节点 7 变量平铺）
DIFY_CHECKIN_API_KEY=app-your_dify_checkin_api_key
DIFY_CHECKIN_RESPONSE_MODE=blocking

# 食物图片识别工作流（checkin-service，开始节点 6 变量平铺）
DIFY_FOOD_RECOGNITION_API_KEY=app-your_dify_food_recognition_api_key
DIFY_FOOD_RECOGNITION_RESPONSE_MODE=blocking
# Dify 拉取打卡图片须用公网 URL；本地开发：ngrok http 9000 后填 https://xxxx.ngrok-free.app
DIFY_FOOD_RECOGNITION_IMAGE_PUBLIC_BASE_URL=

# 科普问答 Chatbot（home-service，Milvus 预检索 + Dify Chat API streaming）
DIFY_QA_API_KEY=app-your_dify_qa_api_key

# 科普助手语音识别 — 阿里云百炼 Fun-ASR（home-service 直连，不再走 Dify 工作流）
DASHSCOPE_API_KEY=sk-your_dashscope_api_key
DASHSCOPE_STT_MODEL=fun-asr
DASHSCOPE_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/api/v1
STT_MAX_AUDIO_BYTES=5242880
# Fun-ASR 须通过公网 HTTP 拉取音频；本地开发可用 ngrok 暴露 MinIO，或填公网 MinIO 地址
STT_AUDIO_PUBLIC_BASE_URL=http://localhost:9000

# 资讯详情页语音朗读 — 阿里云百炼 qwen3-tts-flash（article-service 直连，blocking 非流式）
DASHSCOPE_TTS_ENABLED=true
DASHSCOPE_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_TTS_VOICE=CHERRY
DASHSCOPE_TTS_LANGUAGE=Chinese
DASHSCOPE_TTS_MAX_CHUNK_CHARS=400

# AI 模拟医生问诊工作流（consultation-service，开始节点 6 变量平铺）
DIFY_CONSULTATION_API_KEY=app-your_dify_consultation_api_key
DIFY_CONSULTATION_RESPONSE_MODE=blocking
DIFY_CONSULTATION_TIMEOUT_SECONDS=120

# Dify 调用 health-service 内部 API（Header: X-Dify-Key）
DIFY_INTERNAL_KEY=your_dify_internal_key

# Milvus（article-service 语义推荐 Phase 3）
MILVUS_ENABLED=true
MILVUS_HOST=localhost
MILVUS_PORT=19530
# 须与 Embedding 模型输出维度一致（qwen3-embedding:0.6b=1024，nomic-embed-text=768，local=384）
MILVUS_DIMENSION=1024
# local=内置哈希向量；openai=OpenAI 兼容 API（Ollama / OpenAI / DashScope 等）
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_MODEL=qwen3-embedding:0.6b

# Kingbase（Dify 内置数据库，docker-compose 中 kingbase 服务）
KINGBASE_PASSWORD=your_kingbase_password
